---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection, type CollectionEntry } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import ogImage from '../../assets/pwnfuzz-labs.jpg';

const breakdownsUnprocessed = (await getCollection('breakdowns')).sort(
  (a: CollectionEntry<'breakdowns'>, b: CollectionEntry<'breakdowns'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const breakdowns = await Promise.all(
  breakdownsUnprocessed.map(async (breakdown) => {
    const wordCount = (breakdown.body || '').split(/\s+/).length;
    const readingTime = `${Math.max(1, Math.ceil(wordCount / 200))} min read`;
    return {
      ...breakdown,
      readingTime,
    };
  })
);

const BREAKDOWNS_PER_PAGE = 10;
const paginatedBreakdowns = breakdowns; // Pass all
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`1Day Breakdowns | ${SITE_TITLE}`} description="Quick technical breakdowns and analyses of recent 1Day vulnerabilities and exploits." />
  </head>
  <body>
    <Header />
    <main class="container index-main animate-fade-in">
      <section class="latest-research">
        <div class="section-header">
          <h2 class="section-title">All Breakdowns</h2>
        </div>
        
        <div class="research-list">
          {paginatedBreakdowns.map((breakdown) => (
            <article 
              class="research-card" 
              data-title={breakdown.data.title.toLowerCase()} 
              data-summary={(breakdown.data.summary || breakdown.data.description || "").toLowerCase()} 
              data-tags={(breakdown.data.tags || []).join(' ').toLowerCase()}
            >
              <div class="card-meta">
                <span class="card-date"><FormattedDate date={breakdown.data.pubDate} /></span>
                <span class="card-read">{breakdown.readingTime}</span>
              </div>
              <div class="card-inner">
                <a href={`/breakdowns/${breakdown.id}/`} class="card-title-link">
                  <h3 class="card-title">{breakdown.data.title}</h3>
                </a>
                <p class="card-summary">{breakdown.data.summary || breakdown.data.description}</p>
                <div class="card-tags">
                  {breakdown.data.tags?.map(tag => (
                    <a href={`/tags/${tag}/`} class="tag-link">#{tag.toLowerCase()}</a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      {paginatedBreakdowns.length > 6 && (
        <div class="load-more-container animate-fade-in">
          <button id="load-more" type="button">
            Load More Breakdowns
            <span class="arrow">&rarr;</span>
          </button>
        </div>
      )}

      <script>
        function setupLoadMore() {
          const loadMoreBtn = document.getElementById('load-more');
          if (!loadMoreBtn) return;

          loadMoreBtn.addEventListener('click', (e) => {
            e.preventDefault();
            const hiddenPosts = Array.from(document.querySelectorAll('.post-item.hidden'));
            const perPage = 6;
            const nextBatch = hiddenPosts.slice(0, perPage);
            
            nextBatch.forEach((post, i) => {
              setTimeout(() => {
                post.classList.remove('hidden');
                post.classList.add('animate-fade-in');
              }, i * 50);
            });

            if (hiddenPosts.length <= perPage) {
              loadMoreBtn.parentElement.style.display = 'none';
            }
          });
        }

        // Initialize
        setupLoadMore();
        // For View Transitions consistency
        document.addEventListener('astro:page-load', setupLoadMore);
      </script>
    </main>
    <Footer />

    <style>
      .index-main {
        max-width: 1200px;
        margin: 0 auto;
        padding: var(--spacing-12) 1.5rem;
      }

      .latest-research {
        margin-top: var(--spacing-4);
      }

      .section-header {
        border-bottom: 1px solid var(--border-subtle);
        padding-bottom: var(--spacing-6);
        margin-bottom: var(--spacing-8);
      }

      .section-title {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 700;
        margin: 0;
        font-family: var(--font-display);
        color: var(--on-surface);
        letter-spacing: -0.02em;
      }

      /* Premium Ledger list layout (replacing cards) */
      .research-list {
        display: flex;
        flex-direction: column;
      }

      .research-card {
        transition: opacity 0.2s ease;
      }

      article.research-card {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 2rem;
        padding: 1.75rem 0.75rem;
        border-bottom: 1px solid var(--border-subtle);
        border-left: 3px solid transparent;
        background: transparent;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }

      article.research-card:hover {
        border-left-color: var(--primary-accent);
        padding-left: 1.25rem;
        background-color: var(--surface-low);
      }

      .card-inner {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .card-meta {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--on-surface-muted);
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        justify-content: flex-start;
        padding-top: 0.25rem;
      }

      .card-title-link {
        text-decoration: none;
        color: inherit;
      }

      .card-title {
        font-size: 1.5rem;
        line-height: 1.2;
        margin: 0;
        font-family: var(--font-display);
        color: var(--on-surface);
        font-weight: 700;
        transition: color 0.15s ease;
      }

      .card-title-link:hover .card-title {
        color: var(--primary-accent);
      }

      .card-summary {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--on-surface-variant);
        margin: 0;
      }

      .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 0.25rem;
      }

      .tag-link {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--on-surface-muted);
        text-decoration: none;
        transition: color 0.15s ease;
        border: 1px solid var(--border-subtle);
        padding: 0.25rem 0.6rem;
        background: var(--surface-low);
        border-radius: var(--radius-sm);
      }

      .tag-link:hover {
        color: var(--primary-accent);
        border-color: var(--primary-accent);
      }

      .no-posts {
        text-align: center;
        padding: 4rem 0;
        color: var(--on-surface-muted);
        font-style: italic;
      }

      @media (max-width: 768px) {
        article.research-card {
          grid-template-columns: 1fr;
          gap: 0.5rem;
          padding: 1.5rem 0.5rem;
        }

        article.research-card:hover {
          padding-left: 0.75rem;
        }

        .card-meta {
          flex-direction: row;
          gap: 0.5rem;
        }
      }
    </style>
  </body>
</html>