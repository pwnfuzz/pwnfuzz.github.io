---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection, type CollectionEntry } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import ogImage from '../../assets/pwnfuzz-labs.jpg';

const breakdownsUnprocessed = (await getCollection('breakdowns')).sort(
  (a: CollectionEntry<'breakdowns'>, b: CollectionEntry<'breakdowns'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const breakdowns = await Promise.all(
  breakdownsUnprocessed.map(async (breakdown) => {
    const wordCount = (breakdown.body || '').split(/\s+/).length;
    const readingTime = `${Math.max(1, Math.ceil(wordCount / 200))} min read`;
    return {
      ...breakdown,
      readingTime,
    };
  })
);

const BREAKDOWNS_PER_PAGE = 10;
const paginatedBreakdowns = breakdowns; // Pass all
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`1Day Breakdowns | ${SITE_TITLE}`} description="Quick technical breakdowns and analyses of recent 1Day vulnerabilities and exploits." />
  </head>
  <body>
    <Header />
    <main class="container">
      <section class="latest-research animate-fade-in">
        <div class="section-header">
          <h2 class="section-title">All Breakdowns</h2>
        </div>
        
        <div class="research-grid">
          {paginatedBreakdowns.map((breakdown) => (
            <div 
              class="research-card" 
              data-title={breakdown.data.title.toLowerCase()} 
              data-summary={(breakdown.data.summary || breakdown.data.description || "").toLowerCase()} 
              data-tags={(breakdown.data.tags || []).join(' ').toLowerCase()}
            >
              <a href={`/breakdowns/${breakdown.id}/`} class="card-link">
                <div class="card-tags">
                  {breakdown.data.tags?.map(tag => <span class="tag">#{tag.toUpperCase()}</span>)}
                </div>
                <h3 class="card-title">{breakdown.data.title}</h3>
                <p class="card-summary">{breakdown.data.summary || breakdown.data.description}</p>
                <div class="card-meta">
                  <FormattedDate date={breakdown.data.pubDate} />
                  <span>{breakdown.readingTime}</span>
                </div>
              </a>
            </div>
          ))}
        </div>
      </section>

      {paginatedBreakdowns.length > 6 && (
        <div class="load-more-container animate-fade-in">
          <button id="load-more" type="button">
            Load More Breakdowns
            <span class="arrow">&rarr;</span>
          </button>
        </div>
      )}

      <script>
        function setupLoadMore() {
          const loadMoreBtn = document.getElementById('load-more');
          if (!loadMoreBtn) return;

          loadMoreBtn.addEventListener('click', (e) => {
            e.preventDefault();
            const hiddenPosts = Array.from(document.querySelectorAll('.post-item.hidden'));
            const perPage = 6;
            const nextBatch = hiddenPosts.slice(0, perPage);
            
            nextBatch.forEach((post, i) => {
              setTimeout(() => {
                post.classList.remove('hidden');
                post.classList.add('animate-fade-in');
              }, i * 50);
            });

            if (hiddenPosts.length <= perPage) {
              loadMoreBtn.parentElement.style.display = 'none';
            }
          });
        }

        // Initialize
        setupLoadMore();
        // For View Transitions consistency
        document.addEventListener('astro:page-load', setupLoadMore);
      </script>
    </main>
    <Footer />

    <style>
      .latest-research {
        margin-top: var(--spacing-20);
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding-bottom: var(--spacing-6);
        border-bottom: 1px solid var(--surface-low);
        margin-bottom: var(--spacing-10);
      }

      .section-title {
        font-size: 2rem;
        margin: 0;
      }

      .research-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: var(--spacing-12);
        align-items: stretch;
      }

      .research-card {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: var(--spacing-6);
        background: var(--surface-low);
        padding: var(--spacing-8);
        border-radius: var(--radius-sm);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
      }

      :global([data-theme="dark"]) .research-card {
        border-color: rgba(255,255,255,0.05);
      }

      .research-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-ambient);
      }
      
      .card-link {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        height: 100%;
      }

      .sidebar-cards {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-10);
      }

      .card-advisory {
        padding: var(--spacing-10);
        background: var(--surface-low);
        border-radius: var(--radius-sm);
        display: flex;
        flex-direction: column;
        gap: var(--spacing-6);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .card-advisory:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-ambient);
      }

      .card-label-small {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--primary-accent);
        font-weight: 700;
        letter-spacing: 0.1em;
      }

      .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: var(--spacing-4);
      }

      .card-tags .tag {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--primary-accent);
        font-weight: 600;
        transition: opacity 0.2s ease;
      }
      .card-tags .tag:hover {
        opacity: 0.8;
      }

      .research-card .card-title {
        color: var(--primary);
        font-size: 1.5rem;
        line-height: 1.3;
        margin: 0;
        margin-bottom: var(--spacing-4);
        font-weight: 700;
      }

      .card-summary {
        color: var(--on-surface-variant);
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: var(--spacing-6);
        flex-grow: 1;
      }

      .card-meta {
        color: var(--on-surface-muted);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        display: flex;
        gap: 1.5rem;
        margin-top: auto;
      }


      .no-posts {
        text-align: center;
        padding: 4rem;
        color: var(--fg-muted);
        font-style: italic;
      }

      @media (max-width: 640px) {
        .page-title {
          font-size: 2rem;
        }
        
        .intro-section {
          padding: 3rem 0 2rem 0;
          margin-bottom: 2rem;
        }
      }
    </style>
  </body>
</html>