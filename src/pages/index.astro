---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { getCollection, type CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const postsUnprocessed = (await getCollection('blog')).sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const posts = await Promise.all(
  postsUnprocessed.map(async (post) => {
    const wordCount = (post.body || '').split(/\s+/).length;
    const readingTime = `${Math.max(1, Math.ceil(wordCount / 200))} min read`;
    return {
      ...post,
      readingTime,
    };
  })
);

const featuredPost = posts[0];
const remainingPosts = posts.slice(1);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Research | ${SITE_TITLE}`} description="Technical writeups and security research from PWNFUZZ LABS." />
  </head>
  <body>
    <Header />
    
    <main class="container index-main">
      <!-- Featured Post (Hero) -->
      {featuredPost && (
        <section class="featured-hero animate-fade-in research-card"
          data-title={featuredPost.data.title.toLowerCase()} 
          data-summary={(featuredPost.data.summary || featuredPost.data.description || "").toLowerCase()} 
          data-tags={(featuredPost.data.tags || []).join(' ').toLowerCase()}
        >
          <div class="hero-inner-box">
            <div class="hero-meta">
              <span class="badge badge-primary">Featured Analysis</span>
              <span class="meta-date">
                <FormattedDate date={featuredPost.data.pubDate} />
              </span>
              <span class="meta-divider">&middot;</span>
              <span class="meta-read">{featuredPost.readingTime}</span>
            </div>
            
            <a href={`/posts/${featuredPost.id}/`} class="hero-link">
              <h1 class="hero-title">{featuredPost.data.title}</h1>
            </a>
            
            <p class="hero-summary">{featuredPost.data.summary || featuredPost.data.description}</p>
            
            <div class="hero-tags">
              {featuredPost.data.tags?.map(tag => (
                <a href={`/tags/${tag}/`} class="tag-link">#{tag.toLowerCase()}</a>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Latest Research Section -->
      <section class="latest-research animate-fade-in">
        <div class="section-header">
          <h2 class="section-title">Latest Findings</h2>
          <a href="/tags/" class="all-tags-link">Browse by Tags &rarr;</a>
        </div>
        
        {remainingPosts.length > 0 ? (
          <div class="research-list">
            {remainingPosts.map((post) => (
              <article 
                class="research-card" 
                data-title={post.data.title.toLowerCase()} 
                data-summary={(post.data.summary || post.data.description || "").toLowerCase()} 
                data-tags={(post.data.tags || []).join(' ').toLowerCase()}
              >
                <div class="card-meta">
                  <span class="card-date"><FormattedDate date={post.data.pubDate} /></span>
                  <span class="card-read">{post.readingTime}</span>
                </div>
                <div class="card-inner">
                  <a href={`/posts/${post.id}/`} class="card-title-link">
                    <h3 class="card-title">{post.data.title}</h3>
                  </a>
                  <p class="card-summary">{post.data.summary || post.data.description}</p>
                  <div class="card-tags">
                    {post.data.tags?.map(tag => (
                      <a href={`/tags/${tag}/`} class="tag-link">#{tag.toLowerCase()}</a>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="no-posts">
            <p>No additional research articles found.</p>
          </div>
        )}
      </section>

      <!-- Newsletter Section -->
      <section class="newsletter-section animate-fade-in">
        <div class="newsletter-inner">
          <div class="newsletter-content">
            <span class="newsletter-badge">Stay Updated</span>
            <h2 class="newsletter-title">Sign up for research alerts</h2>
            <p class="newsletter-desc">Deep-dives, exploit forensics, and JIT vulnerability analysis sent straight to your inbox.</p>
          </div>
          <form class="newsletter-form" onsubmit="event.preventDefault(); alert('Subscribed successfully!');">
            <input type="email" placeholder="Enter your email address" required />
            <button type="submit" class="btn-join">SUBSCRIBE</button>
          </form>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .index-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Featured Hero styling */
  .featured-hero {
    display: block;
    padding: var(--spacing-12) 0;
    margin-bottom: var(--spacing-4);
    border-bottom: 1px solid var(--border-subtle);
  }

  .hero-inner-box {
    max-width: 920px;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: var(--spacing-6);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--on-surface-muted);
  }

  .meta-divider {
    color: var(--border-strong);
  }

  .hero-link {
    text-decoration: none;
    color: inherit;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4.25rem);
    line-height: 1.02;
    font-weight: 700;
    margin-bottom: var(--spacing-6);
    color: var(--on-surface);
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
  }

  .hero-link:hover .hero-title {
    color: var(--primary-accent);
  }

  .hero-summary {
    font-size: 1.15rem;
    color: var(--on-surface-variant);
    line-height: 1.7;
    margin-bottom: var(--spacing-6);
    border-left: 2px solid var(--border-strong);
    padding-left: var(--spacing-4);
  }

  .hero-tags, .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tag-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--on-surface-muted);
    text-decoration: none;
    transition: color 0.15s ease;
    border: 1px solid var(--border-subtle);
    padding: 0.25rem 0.6rem;
    background: var(--surface-low);
    border-radius: var(--radius-sm);
  }

  .tag-link:hover {
    color: var(--primary-accent);
    border-color: var(--primary-accent);
  }

  /* Latest Research styling */
  .latest-research {
    margin-top: var(--spacing-12);
    margin-bottom: var(--spacing-12);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: var(--spacing-4);
    margin-bottom: var(--spacing-4);
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0;
    font-family: var(--font-display);
  }

  .all-tags-link {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--primary-accent);
    text-decoration: none;
  }

  .all-tags-link:hover {
    text-decoration: underline;
  }

  /* Premium Ledger list layout (replacing cards) */
  .research-list {
    display: flex;
    flex-direction: column;
  }

  .research-card {
    transition: opacity 0.2s ease;
  }

  article.research-card {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
    padding: 1.75rem 0.75rem;
    border-bottom: 1px solid var(--border-subtle);
    border-left: 3px solid transparent;
    background: transparent;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  article.research-card:hover {
    border-left-color: var(--primary-accent);
    padding-left: 1.25rem;
    background-color: var(--surface-low);
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--on-surface-muted);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    justify-content: flex-start;
    padding-top: 0.25rem;
  }

  .card-title-link {
    text-decoration: none;
    color: inherit;
  }

  .card-title {
    font-size: 1.5rem;
    line-height: 1.2;
    margin: 0;
    font-family: var(--font-display);
    color: var(--on-surface);
    font-weight: 700;
    transition: color 0.15s ease;
  }

  .card-title-link:hover .card-title {
    color: var(--primary-accent);
  }

  .card-summary {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--on-surface-variant);
    margin: 0;
  }

  .card-tags {
    margin-top: 0.25rem;
  }

  .no-posts {
    text-align: center;
    padding: var(--spacing-12) 0;
    color: var(--on-surface-muted);
    font-style: italic;
  }

  @media (max-width: 768px) {
    article.research-card {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      padding: 1.5rem 0.5rem;
    }

    article.research-card:hover {
      padding-left: 0.75rem;
    }

    .card-meta {
      flex-direction: row;
      gap: 0.5rem;
    }
  }

  .no-posts {
    text-align: center;
    padding: var(--spacing-12) 0;
    color: var(--on-surface-muted);
    font-style: italic;
  }

  /* Newsletter Box styling */
  .newsletter-section {
    margin: var(--spacing-20) 0 var(--spacing-10) 0;
    border: 1px solid var(--border-subtle);
    background: var(--surface-low);
    border-radius: var(--radius-md);
    padding: 2.5rem;
  }

  .newsletter-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .newsletter-content {
    max-width: 520px;
  }

  .newsletter-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--primary-accent);
    margin-bottom: 0.5rem;
  }

  .newsletter-title {
    font-size: 2rem;
    margin: 0 0 0.5rem 0;
    font-family: var(--font-display);
    color: var(--on-surface);
  }

  .newsletter-desc {
    font-size: 0.95rem;
    color: var(--on-surface-variant);
    margin: 0;
    line-height: 1.5;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    flex-grow: 1;
    max-width: 460px;
  }

  .newsletter-form input {
    background: var(--background);
    border: 1px solid var(--border-subtle);
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--on-surface);
    border-radius: var(--radius-sm);
    outline: none;
    flex-grow: 1;
    transition: border-color 0.2s ease;
  }

  .newsletter-form input:focus {
    border-color: var(--primary-accent);
  }

  .btn-join {
    background: var(--primary-accent);
    color: var(--on-primary);
    border: none;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .btn-join:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .newsletter-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .newsletter-form {
      width: 100%;
      max-width: 100%;
    }
  }
</style>
