---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection, type CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import ogImage from '../assets/pwnfuzz-labs.jpg';

const postsUnprocessed = (await getCollection('blog')).sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const posts = await Promise.all(
  postsUnprocessed.map(async (post) => {
    const wordCount = (post.body || '').split(/\s+/).length;
    const readingTime = `${Math.max(1, Math.ceil(wordCount / 200))} min read`;
    return {
      ...post,
      readingTime,
    };
  })
);

const featuredPost = posts[0];
const researchPosts = posts.slice(1, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Research | ${SITE_TITLE}`} description="Technical writeups and security research." />
  </head>
  <body>
    <Header />
    <main class="container">
      {featuredPost && (
        <section class="featured-hero animate-fade-in">
          <div class="hero-content">
            <div class="hero-meta">
              <span class="badge badge-primary">FEATURED ANALYSIS</span>
              <span class="meta-date">
                <FormattedDate date={featuredPost.data.pubDate} />
              </span>
            </div>
            <a href={`/posts/${featuredPost.id}/`} class="hero-link">
              <h1 class="hero-title">{featuredPost.data.title}</h1>
            </a>
            <p class="hero-summary">{featuredPost.data.summary || featuredPost.data.description}</p>
          </div>
        </section>
      )}

      <section class="latest-research animate-fade-in">
        <div class="section-header">
          <h2 class="section-title">Latest Research</h2>
        </div>
        
        <div class="research-grid">
          {posts.slice(1).map((post) => (
            <div 
              class="research-card" 
              data-title={post.data.title.toLowerCase()} 
              data-summary={(post.data.summary || post.data.description || "").toLowerCase()} 
              data-tags={(post.data.tags || []).join(' ').toLowerCase()}
            >
              <a href={`/posts/${post.id}/`} class="card-link">
                <div class="card-tags">
                  {post.data.tags?.map(tag => <span class="tag">#{tag.toUpperCase()}</span>)}
                </div>
                <h3 class="card-title">{post.data.title}</h3>
                <p class="card-summary">{post.data.summary || post.data.description}</p>
                <div class="card-meta">
                  <FormattedDate date={post.data.pubDate} />
                  <span>{post.readingTime}</span>
                </div>
              </a>
            </div>
          ))}
        </div>
      </section>

      <section class="newsletter-section animate-fade-in">
        <div class="newsletter-content">
          <h2 class="newsletter-title">Newsletter coming soon.</h2>
        </div>
      </section>

      <script>
        function setupLoadMore() {
          const loadMoreBtn = document.getElementById('load-more');
          if (!loadMoreBtn) return;

          loadMoreBtn.addEventListener('click', (e) => {
            e.preventDefault();
            const hiddenPosts = Array.from(document.querySelectorAll('.post-item.hidden'));
            const perPage = 6;
            const nextBatch = hiddenPosts.slice(0, perPage);
            
            nextBatch.forEach((post, i) => {
              setTimeout(() => {
                post.classList.remove('hidden');
                post.classList.add('animate-fade-in');
              }, i * 50);
            });

            if (hiddenPosts.length <= perPage) {
              loadMoreBtn.parentElement.style.display = 'none';
            }
          });
        }

        // Initialize
        setupLoadMore();
        // For View Transitions consistency
        document.addEventListener('astro:page-load', setupLoadMore);
      </script>
    </main>
    <Footer />

    <style>
      .featured-hero {
        display: block;
        padding: var(--spacing-20) 0;
        text-align: left;
      }

      .hero-meta {
        display: flex;
        align-items: center;
        gap: var(--spacing-4);
        margin-bottom: var(--spacing-8);
      }

      .meta-date {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--on-surface-muted);
      }

      .hero-title {
        font-size: 6rem;
        line-height: 0.95;
        font-weight: 700;
        letter-spacing: -0.05em;
        margin-bottom: var(--spacing-10);
        color: var(--primary);
      }

      .hero-summary {
        font-size: 1.25rem;
        color: var(--on-surface-variant);
        line-height: 1.5;
        max-width: 600px;
        border-left: 1px solid var(--surface-container);
        padding-left: var(--spacing-6);
      }

      .vulnerability-card {
        background: #ffffff;
        padding: var(--spacing-10);
        box-shadow: var(--shadow-ambient-lg);
        border-radius: var(--radius-sm);
        display: flex;
        flex-direction: column;
        gap: var(--spacing-6);
      }

      .vulnerability-card .card-label {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--primary-accent);
        font-weight: 700;
        letter-spacing: 0.05em;
      }

      .cve-id {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--primary);
      }

      .cvss-score {
        font-size: 2.5rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .severity-badge {
        background: var(--primary-accent);
        color: #ffffff;
        font-size: 0.75rem;
        padding: 0.2rem 0.5rem;
        border-radius: var(--radius-sm);
      }

      /* Latest Research Section */
      .latest-research {
        margin-top: var(--spacing-20);
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding-bottom: var(--spacing-6);
        border-bottom: 1px solid var(--surface-low);
        margin-bottom: var(--spacing-10);
      }

      .section-title {
        font-size: 2rem;
        margin: 0;
      }

      .full-archive-link {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--primary-accent);
        font-weight: 700;
        text-transform: uppercase;
      }

      .research-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: var(--spacing-12);
        align-items: stretch;
      }

      .research-card {
        display: flex;
        flex-direction: column;
        height: 100%;
        gap: var(--spacing-6);
        background: var(--surface-low);
        padding: var(--spacing-8);
        border-radius: var(--radius-sm);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
      }

      :global([data-theme="dark"]) .research-card {
        border-color: rgba(255,255,255,0.05);
      }

      .research-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-ambient);
      }

      .card-link {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        height: 100%;
      }

      .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: var(--spacing-4);
      }

      .card-tags .tag {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--primary-accent);
        font-weight: 600;
        transition: opacity 0.2s ease;
      }
      .card-tags .tag:hover {
        opacity: 0.8;
      }

      .research-card .card-title {
        color: var(--primary);
        font-size: 1.5rem;
        line-height: 1.3;
        margin: 0;
        margin-bottom: var(--spacing-4);
        font-weight: 700;
      }

      .card-summary {
        color: var(--on-surface-variant);
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: var(--spacing-6);
        flex-grow: 1;
      }

      .card-meta {
        color: var(--on-surface-muted);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        display: flex;
        gap: 1.5rem;
        margin-top: auto;
      }

      .sidebar-cards {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-10);
      }

      .card-advisory, .card-lab-notes, .card-small {
        padding: var(--spacing-10);
        background: var(--surface-low);
        border-radius: var(--radius-sm);
        display: flex;
        flex-direction: column;
        gap: var(--spacing-6);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .card-advisory:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-ambient);
      }

      .card-lab-notes {
        background: var(--inverse-surface);
        color: #ffffff;
      }

      .card-label-small {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--primary-accent);
        font-weight: 700;
        letter-spacing: 0.1em;
      }

      .card-advisory .card-title {
        font-size: 1.25rem;
      }

      .card-lab-notes .card-title {
        font-size: 1.5rem;
        margin-bottom: var(--spacing-10);
      }

      .card-lab-notes .card-footer {
        display: flex;
        justify-content: space-between;
        font-family: var(--font-mono);
        font-size: 0.7rem;
      }

      .card-small img {
        width: 100%;
        height: 120px;
        object-fit: cover;
        margin-bottom: var(--spacing-4);
      }

      .card-small .card-title {
        font-size: 1.15rem;
      }

      /* Newsletter Section */
      .newsletter-section {
        margin: var(--spacing-20) 0;
        padding: var(--spacing-12);
        background: var(--surface-low);
        border-radius: var(--radius-sm);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--spacing-12);
        border-left: 4px solid var(--primary-accent);
      }

      .newsletter-content {
        max-width: 500px;
      }

      .newsletter-title {
        font-size: 2.5rem;
        margin-bottom: var(--spacing-4);
      }

      .newsletter-summary {
        font-size: 1rem;
        color: var(--on-surface-variant);
        line-height: 1.5;
      }

      .newsletter-form-wrapper {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .newsletter-form {
        display: flex;
        background: #ffffff;
        padding: 0.25rem;
        border-radius: var(--radius-sm);
        box-shadow: var(--shadow-ambient);
      }

      .newsletter-form input {
        border: none;
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
        outline: none;
        width: 250px;
      }

      .btn-join {
        background: var(--inverse-surface);
        color: #ffffff;
        border: none;
        padding: 0.75rem 1.5rem;
        font-weight: 700;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        border-radius: var(--radius-sm);
        cursor: pointer;
      }

      .form-disclaimer {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--on-surface-muted);
        letter-spacing: 0.05em;
      }

      .no-posts {
        text-align: center;
        padding: 4rem;
        color: var(--fg-muted);
        font-style: italic;
      }

      @media (max-width: 640px) {
        .page-title {
          font-size: 2rem;
        }
        
        .intro-section {
          padding: 3rem 0 2rem 0;
          margin-bottom: 2rem;
        }
      }
    </style>
  </body>
</html>
