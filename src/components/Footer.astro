---
const today = new Date();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <div class="footer-logo">
        <span class="logo-dot"></span>
        <span class="logo-text">pwnfuzz</span>
        <span class="logo-suffix">labs</span>
      </div>
      <p class="brand-sub">
        &copy; {today.getFullYear()} PWNFUZZ LABS. <br/>
        FORENSIC LEDGER METHODOLOGY. <br/>
        ALL RIGHTS RESERVED.
      </p>
    </div>
    
    <div class="footer-columns">
      <div class="footer-col">
        <h5 class="col-title">LEGAL</h5>
        <ul class="footer-links">
          <li><a href="/privacy/">Security Policy</a></li>
          <li><a href="/pgp/">PGP Key</a></li>
          <li><a href="/legal/">Legal Disclaimer</a></li>
        </ul>
      </div>
      
      <div class="footer-col">
        <h5 class="col-title">CONNECT</h5>
        <ul class="footer-links">
          <li><a href="https://twitter.com/pwnfuzz" target="_blank">X / Twitter</a></li>
          <li><a href="https://github.com/pwnfuzz" target="_blank">GitHub</a></li>
          <li><a href="/rss.xml">RSS Feed</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 6rem 0 4rem 0;
    background: var(--background);
    border-top: 1px solid var(--border-subtle);
    margin-top: 8rem;
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }

  .logo-dot {
    width: 6px;
    height: 6px;
    background-color: var(--primary-accent);
    border-radius: 1px;
  }

  .logo-suffix {
    color: var(--on-surface-muted);
    font-weight: 400;
  }

  .brand-sub {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    line-height: 1.8;
    color: var(--on-surface-muted);
    letter-spacing: 0.08em;
  }

  .footer-columns {
    display: flex;
    gap: 5rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
  }

  .col-title {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--on-surface);
    margin-bottom: 1.25rem;
    letter-spacing: 0.1em;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links a {
    color: var(--on-surface-variant);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--primary-accent);
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      gap: 3.5rem;
    }
    
    .footer-columns {
      gap: 3.5rem;
    }
  }
</style>
