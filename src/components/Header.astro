---
const navLinks = [
  { href: '/', label: 'Research' },
  { href: '/breakdowns/', label: 'Breakdowns' },
];
---

<header class="site-header" id="siteHeader">
  <div class="header-inner container">
    <a href="/" class="site-logo">
      <span class="logo-text">pwnfuzz</span>
      <span class="logo-suffix">labs</span>
    </a>
    <nav class="main-nav">
      <ul>
        {navLinks.map(link => (
          <li>
            <a 
              href={link.href} 
              class={Astro.url.pathname === link.href ? 'active' : ''} 
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="header-actions">
      <div class="search-bar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" placeholder="Search findings..." />
      </div>
      <button class="btn-subscribe">Subscribe</button>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle Theme">
        <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    background: rgba(247, 249, 255, 0.8); /* surface at 80% */
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  :global([data-theme="dark"]) .site-header {
    background: rgba(14, 15, 22, 0.8);
  }

  .site-header.hide {
    transform: translateY(-100%);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--on-surface);
    text-decoration: none;
    letter-spacing: -0.04em;
  }

  .logo-text {
    color: var(--fg-primary);
  }

  .logo-suffix {
    color: var(--fg-muted);
    font-size: 0.9em;
    font-weight: 500;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .main-nav ul {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .main-nav a {
    color: var(--on-surface-variant);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.5rem 0.5rem;
    transition: all 0.3s ease;
    text-decoration: none;
    position: relative;
  }

  .main-nav a:hover {
    color: var(--on-surface);
  }

  .main-nav a.active {
    color: var(--primary-accent);
  }

  .main-nav a.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0.5rem;
    right: 0.5rem;
    height: 2px;
    background-color: var(--primary-accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--surface-low);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    color: var(--on-surface-muted);
  }

  .search-bar input {
    background: none;
    border: none;
    font-size: 0.85rem;
    color: var(--on-surface);
    outline: none;
    width: 15rem;
  }

  .btn-subscribe {
    background-color: var(--primary-accent);
    color: #ffffff;
    border: none;
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .btn-subscribe:hover {
    opacity: 0.9;
  }

  /* Remove old underline styles */
  .main-nav a.active::after {
    display: none;
  }

  /* Theme Toggle */
  .theme-toggle {
    background: none;
    border: 1px solid var(--border-subtle);
    cursor: pointer;
    color: var(--fg-secondary);
    padding: 0.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-left: 0.5rem;
  }

  .theme-toggle:hover {
    color: var(--accent-primary);
    background-color: var(--bg-card-hover);
    border-color: var(--accent-primary);
    transform: scale(1.1);
    box-shadow: 0 0 12px rgba(255, 158, 100, 0.3);
  }

  .sun-icon {
    display: none;
  }

  .moon-icon {
    display: block;
  }

  /* Show sun icon in dark mode */
  :global([data-theme="dark"]) .sun-icon {
    display: block;
  }

  :global([data-theme="dark"]) .moon-icon {
    display: none;
  }

  @media (max-width: 768px) {
    .header-inner {
      flex-direction: column;
      height: auto;
      padding: 1rem;
      gap: 1rem;
    }
    
    .main-nav {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }

    .main-nav ul {
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>

<script is:inline>
  // Initialize theme immediately to prevent flash
  const theme = (() => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
      return 'dark';
    }
    return 'light';
  })();

  if (theme === 'dark') {
    document.documentElement.setAttribute('data-theme', 'dark');
  } else {
    document.documentElement.removeAttribute('data-theme');
  }

  window.localStorage.setItem('theme', theme);
</script>

<script>
  // Toggle Logic
  const handleToggleClick = () => {
    const element = document.documentElement;
    const currentTheme = element.getAttribute('data-theme');
    const isDark = currentTheme === 'dark';

    if (isDark) {
      element.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
    } else {
      element.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
    }
  };

    const toggleBtn = document.getElementById('themeToggle');
    if (toggleBtn) {
      toggleBtn.addEventListener('click', handleToggleClick);
    }

    // Header Scroll Logic
    let lastScroll = 0;
    const header = document.getElementById('siteHeader');

    // Only add if not already added by previous load
    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      
      if (currentScroll <= 0) {
        header?.classList.remove('hide');
        return;
      }

      if (currentScroll > lastScroll && currentScroll > 80) {
        // Scrolling down
        header?.classList.add('hide');
      } else {
        // Scrolling up
        header?.classList.remove('hide');
      }
      
      lastScroll = currentScroll;
    });

    // Search Logic
    const searchInput = document.querySelector('.search-bar input');
    searchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();
      const cards = document.querySelectorAll('.research-card');
      
      cards.forEach(card => {
        const title = card.getAttribute('data-title') || '';
        const summary = card.getAttribute('data-summary') || '';
        const tags = card.getAttribute('data-tags') || '';
        
        const isVisible = title.includes(query) || summary.includes(query) || tags.includes(query);
        (card as HTMLElement).style.display = isVisible ? 'flex' : 'none';
      });
    });
</script>
