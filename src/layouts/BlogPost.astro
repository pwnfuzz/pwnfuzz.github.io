---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import ogImage from '../assets/pwnfuzz-labs.jpg';

interface Props extends CollectionEntry<'blog'>['data'] {
  collection?: 'blog' | 'breakdowns';
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, updatedDate, heroImage, collection = 'blog', headings = [] } = Astro.props;

const authorsData: Record<string, { image: string, bio: string, twitter: string, github: string }> = {
  "D4mianWayne": {
    image: "/img/team/d4mianwayne.jpg",
    bio: "Security researcher specializing in fuzzing, reverse engineering, and exploit development. A dedicated pwner exploring the depths of low-level systems.",
    twitter: "https://twitter.com/D4mianWayne",
    github: "https://github.com/D4mianWayne"
  },
  "ghostbyt3": {
    image: "/img/team/ghostbyt3.jpg",
    bio: "Security researcher focusing on red teaming, web application security, and advanced reverse engineering, with a deep interest in Windows internals and exploit development.",
    twitter: "https://twitter.com/ghostbyt3",
    github: "https://github.com/ghostbyt3"
  }
};
const authorName = Astro.props.author || "PwnFuzz Labs";
const normalizedAuthor = authorName.toLowerCase().trim();
const foundKey = Object.keys(authorsData).find(key => key.toLowerCase() === normalizedAuthor);
const authorData = foundKey ? authorsData[foundKey] : {
  image: "/img/pwnfuzz-labs.jpg",
  bio: "Security researcher specializing in binary exploitation and vulnerability research. At pwnfuzz labs, they lead deep-dive forensics into critical vulnerabilities.",
  twitter: "https://twitter.com/pwnfuzz",
  github: "https://github.com/pwnfuzz"
};

const backUrl = collection === 'breakdowns' ? '/breakdowns/' : '/';
const backLabel = collection === 'breakdowns' ? 'Back to Breakdowns' : 'Back to Articles';
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <div class="reading-progress" id="readingProgress"></div>
    <Header />
    <main class="post-main">
      <article class="post-article">
        <div class="post-breadcrumbs container">
          <a href="/" class="breadcrumb" style="text-decoration: none; color: inherit;">PWNFUZZ LABS</a>
          <span class="separator">/</span>
          <a href={backUrl} class="breadcrumb accent" style="text-decoration: none;">
            {collection === 'breakdowns' ? 'BREAKDOWNS' : 'RESEARCH'}
          </a>
        </div>

        <header class="post-header-fidelity container">
          <h1 class="post-title-high">{title}</h1>
          
          <div class="post-meta-high">
            <div class="author-summary">
              <img src={authorData.image} alt={authorName} class="author-avatar-img-mini" />
              <div class="author-details">
                <span class="author-name">{authorName}</span>
                <span class="author-role">SECURITY RESEARCHER</span>
              </div>
            </div>
            <div class="meta-items">
              <span class="meta-item"><FormattedDate date={pubDate} /></span>
              <span class="meta-item"> {Astro.props.readingTime || '10 Min Read'}</span>
            </div>
          </div>
        </header>


        <div class="content-layout">
          <aside class="sidebar-left">
            <div class="case-navigation">
              <h3 class="sidebar-title">CASE NAVIGATION</h3>
              <nav class="case-nav">
                <ul>
                  {headings.filter(h => h.depth <= 3).map((h, i) => (
                    <li class={i === 0 ? 'active' : ''}>
                      <a href={`#${h.slug}`}>
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>

          <div class="prose-wrapper">
            <div class="prose drop-cap">
              <slot />
            </div>
          </div>
        </div>



        <div class="author-bio-card container">
          <div class="bio-content">
            <img src={authorData.image} alt={authorName} class="bio-avatar-img" />
            <div class="bio-text">
              <h4>{authorName}</h4>
              <p>{authorData.bio}</p>
              <div class="bio-links">
                <a href={authorData.twitter} target="_blank">X / TWITTER</a>
                <a href={authorData.github} target="_blank">GITHUB</a>
              </div>
            </div>
          </div>
        </div>

        <div class="post-footer">
          <div class="footer-actions">
            <a href="/archive/" class="back-link">&larr; Back to Research Archive</a>
          </div>
        </div>
      </article>
    </main>

    <!-- Scroll to Top Button -->
    <button id="scrollToTopBtn" class="scroll-to-top" aria-label="Scroll to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <Footer />

    <script>
      // TOC Highlighting Logic
      const tocItems = document.querySelectorAll('.case-nav li');
      const headings = Array.from(document.querySelectorAll('.prose h1, .prose h2, .prose h3'));
      
      if (tocItems.length > 0 && headings.length > 0) {
        const observerOptions = {
          root: null,
          rootMargin: '-100px 0px -66%',
          threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              const activeLink = document.querySelector(`.case-nav a[href="#${id}"]`);
              
              if (activeLink) {
                tocItems.forEach(item => item.classList.remove('active'));
                activeLink.parentElement?.classList.add('active');
              }
            }
          });
        }, observerOptions);

        headings.forEach(h => observer.observe(h));
      }
    </script>

    <script>
      // Reading Progress Indicator
      const progressBar = document.getElementById('readingProgress');
      
      window.addEventListener('scroll', () => {
        const windowHeight = window.innerHeight;
        const documentHeight = document.documentElement.scrollHeight;
        const scrollTop = window.scrollY;
        const scrollPercent = (scrollTop / (documentHeight - windowHeight)) * 100;
        
        if (progressBar) {
          progressBar.style.width = `${Math.min(scrollPercent, 100)}%`;
        }
      });
    </script>

    <script>
      // Share Button Logic
      const copyLinkBtn = document.getElementById('copyLinkBtn');
      const shareTooltip = document.getElementById('shareTooltip');

      if (copyLinkBtn && shareTooltip) {
        copyLinkBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(window.location.href);
            
            // Show tooltip
            shareTooltip.classList.add('visible');
            
            // Hide after 2 seconds
            setTimeout(() => {
              shareTooltip.classList.remove('visible');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy link:', err);
          }
        });
      }
    </script>

    <script>
      // Scroll to Top Button
      const scrollToTopBtn = document.getElementById('scrollToTopBtn');
      
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          scrollToTopBtn?.classList.add('visible');
        } else {
          scrollToTopBtn?.classList.remove('visible');
        }
      });

      scrollToTopBtn?.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    </script>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "image": heroImage ? new URL(heroImage, Astro.site) : undefined,
      "datePublished": pubDate.toISOString(),
      "dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
      "author": {
        "@type": "Person",
        "name": Astro.props.author || "PwnFuzz Labs"
      },
      "description": description
    })} />

    <style>
    .post-main {
      background: var(--surface);
      padding-top: var(--spacing-12);
    }

    .post-breadcrumbs {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--on-surface-muted);
      margin-bottom: var(--spacing-8);
      max-width: 1400px;
      margin-left: auto;
      margin-right: auto;
      padding: 0 2rem;
    }

    .breadcrumb.accent {
      color: var(--primary-accent);
    }

    .post-header-fidelity {
      margin-bottom: var(--spacing-20);
      max-width: 1400px;
      margin-left: auto;
      margin-right: auto;
      padding: 0 2rem;
    }

    .post-title-high {
      font-size: 4.5rem;
      line-height: 1;
      font-weight: 700;
      margin-bottom: var(--spacing-10);
      letter-spacing: -0.04em;
      color: var(--primary);
    }

    .post-meta-high {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: var(--spacing-6);
      border-top: 1px solid var(--surface-low);
    }

    .author-summary {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .author-avatar-img-mini {
      width: 40px;
      height: 40px;
      border-radius: var(--radius-sm);
      object-fit: cover;
      flex-shrink: 0;
      border: 1px solid var(--surface-low);
    }

    .author-details {
      display: flex;
      flex-direction: column;
    }

    .author-name {
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--on-surface);
    }

    .author-role {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      color: var(--on-surface-muted);
      letter-spacing: 0.05em;
    }

    .meta-items {
      display: flex;
      gap: 2rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--on-surface-muted);
    }

    .content-layout {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: var(--spacing-12);
      align-items: start;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .sidebar-left, .sidebar-right {
      position: sticky;
      top: 6rem;
    }

    .sidebar-title {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--on-surface-muted);
      margin-bottom: 1.5rem;
      letter-spacing: 0.1em;
    }

    .case-nav ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .case-nav li {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.85rem;
      color: var(--on-surface-variant);
      cursor: pointer;
      transition: all 0.2s ease;
      padding-left: 1rem;
      border-left: 2px solid transparent;
    }

    .case-nav li.active {
      color: var(--primary-accent);
      font-weight: 600;
      border-left-color: var(--primary-accent);
      background: rgba(255, 107, 107, 0.05);
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }

    .case-nav a {
      color: inherit;
      text-decoration: none;
    }

    .technical-snapshot {
      background: #ffffff;
      padding: 1.5rem;
      box-shadow: var(--shadow-ambient);
      border-radius: var(--radius-sm);
    }

    .snapshot-row {
      display: flex;
      justify-content: space-between;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--surface-low);
      font-size: 0.75rem;
    }

    .snapshot-row:last-child {
      border-bottom: none;
    }

    .snapshot-row .label {
      font-family: var(--font-mono);
      color: var(--on-surface-muted);
      font-weight: 600;
    }

    .snapshot-row .value {
      font-weight: 700;
      color: var(--on-surface);
    }

    .snapshot-row .value.accent {
      color: var(--primary-accent);
    }

    .prose-wrapper {
      max-width: 960px;
    }

    .prose {
      font-size: 1.1rem;
      line-height: 1.8;
      color: var(--on-surface-variant);
    }

    :global(.prose h2) {
      font-size: 2rem;
      margin-top: 4rem;
      margin-bottom: 1.5rem;
      color: var(--primary);
      font-family: var(--font-display);
    }

    .hero-image-container {
      margin-bottom: var(--spacing-20);
    }

    .hero-image {
      width: 100%;
      height: auto;
      border-radius: var(--radius-sm);
      box-shadow: var(--shadow-ambient-lg);
    }

    /* Author Bio Card */
    .author-bio-card {
      margin: var(--spacing-20) auto;
      background: var(--surface-low);
      padding: 3rem;
      border-radius: var(--radius-sm);
      max-width: 900px;
    }

    .bio-content {
      display: flex;
      gap: 2rem;
      align-items: center;
    }

    .bio-avatar-img {
      width: 120px;
      height: 120px;
      border-radius: var(--radius-sm);
      object-fit: cover;
      flex-shrink: 0;
      border: 1px solid var(--surface-low);
    }

    .bio-text h4 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }

    .bio-text p {
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--on-surface-variant);
      margin-bottom: 1.5rem;
    }

    code, pre {
      font-family: var(--font-mono) !important;
    }
    .prose pre code {
      font-size: 0.8rem !important;
    }

    .bio-links {
      display: flex;
      gap: 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 700;
    }

    .bio-links a {
      color: var(--primary-accent);
      text-decoration: none;
    }

    .post-footer {
      padding: var(--spacing-12) 0;
      border-top: 1px solid var(--surface-low);
      max-width: 1400px;
      margin: 0 auto;
      padding-left: 2rem;
      padding-right: 2rem;
    }

    .footer-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .back-link {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--on-surface-muted);
      font-weight: 700;
      text-decoration: none;
    }

    .spread-awareness {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--on-surface-muted);
    }

    @media (max-width: 1200px) {
      .content-layout {
        grid-template-columns: 1fr;
      }
      .sidebar-left, .sidebar-right {
        display: none;
      }
      .prose-wrapper {
        max-width: 100%;
      }
    }
    </style>
  </body>
</html>
```
