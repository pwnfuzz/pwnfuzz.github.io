---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props extends CollectionEntry<'blog'>['data'] {
  collection?: 'blog' | 'breakdowns';
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, updatedDate, collection = 'blog', headings = [] } = Astro.props;

const authorsData: Record<string, { image: string, bio: string, twitter: string, github: string }> = {
  "D4mianWayne": {
    image: "/img/team/d4mianwayne.jpg",
    bio: "Security researcher specializing in fuzzing, reverse engineering, and exploit development. A dedicated pwner exploring the depths of low-level systems.",
    twitter: "https://twitter.com/D4mianWayne",
    github: "https://github.com/D4mianWayne"
  },
  "ghostbyt3": {
    image: "/img/team/ghostbyt3.jpg",
    bio: "Security researcher focusing on red teaming, web application security, and advanced reverse engineering, with a deep interest in Windows internals and exploit development.",
    twitter: "https://twitter.com/ghostbyt3",
    github: "https://github.com/ghostbyt3"
  }
};
const authorName = Astro.props.author || "PwnFuzz Labs";
const normalizedAuthor = authorName.toLowerCase().trim();
const foundKey = Object.keys(authorsData).find(key => key.toLowerCase() === normalizedAuthor);
const authorData = foundKey ? authorsData[foundKey] : {
  image: "/img/pwnfuzz-labs.jpg",
  bio: "Security researcher specializing in binary exploitation and vulnerability research. At pwnfuzz labs, they lead deep-dive forensics into critical vulnerabilities.",
  twitter: "https://twitter.com/pwnfuzz",
  github: "https://github.com/pwnfuzz"
};

const backUrl = collection === 'breakdowns' ? '/breakdowns/' : '/';
const backLabel = collection === 'breakdowns' ? 'BREAKDOWNS' : 'RESEARCH';
---

<html lang="en">
  <head>
    <BaseHead title={`${title} | PWNFUZZ LABS`} description={description} />
  </head>

  <body>
    <div class="reading-progress" id="readingProgress"></div>
    
    <Header />
    
    <main class="post-main">
      <article class="post-article animate-fade-in">
        <!-- Breadcrumbs (Centered) -->
        <div class="post-breadcrumbs container">
          <a href="/" class="breadcrumb">PWNFUZZ LABS</a>
          <span class="separator">/</span>
          <a href={backUrl} class="breadcrumb accent">{backLabel}</a>
        </div>

        <!-- Post Header (Centered, Editorial) -->
        <header class="post-header container">
          <p class="post-eyebrow">
            <span>{collection === 'breakdowns' ? 'Vulnerability Breakdown' : 'Research Writeup'}</span>
            <span class="eyebrow-divider">&middot;</span>
            <span class="pub-date"><FormattedDate date={pubDate} /></span>
          </p>
          
          <h1 class="post-title">{title}</h1>
          
          <div class="post-meta">
            <span class="meta-item author-name">{authorName}</span>
            <span class="meta-divider">&middot;</span>
            <span class="meta-item">{Astro.props.readingTime || '10 Min Read'}</span>
          </div>

          <div class="post-tags-centered">
            {Astro.props.tags?.map((tag: string) => (
              <a href={`/tags/${tag}/`} class="tag-pill">#{tag.toLowerCase()}</a>
            ))}
          </div>
        </header>

        <div class="header-divider container"></div>

        <!-- Post Content & Sidebar Layout -->
        <div class="content-layout">
          <aside class="sidebar-left">
            <div class="toc-wrapper">
              <h3 class="sidebar-title">CASE NAVIGATION</h3>
              <nav class="case-nav">
                <ul>
                  {headings.filter(h => h.depth <= 3).map((h, i) => (
                    <li class={i === 0 ? 'active' : ''}>
                      <a href={`#${h.slug}`}>
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>

          <div class="prose-wrapper">
            <div class="prose">
              <slot />
            </div>
          </div>
        </div>

        <!-- Minimalist Post Footer -->
        <div class="post-footer container">
          <div class="footer-meta">
            <span class="author-label">Written by {authorName}</span>
            <a href={backUrl} class="back-link">&larr; Back to {backLabel.toLowerCase()}</a>
          </div>
        </div>
      </article>
    </main>

    <!-- Scroll to Top Button -->
    <button id="scrollToTopBtn" class="scroll-to-top" aria-label="Scroll to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <Footer />

    <!-- Script: Scroll-to-Top Button Visibility & Scrolling -->
    <script>
      const scrollToTopBtn = document.getElementById('scrollToTopBtn');
      
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) {
          scrollToTopBtn?.classList.add('visible');
        } else {
          scrollToTopBtn?.classList.remove('visible');
        }
      });

      scrollToTopBtn?.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    </script>

    <!-- Script: Reading Progress Bar -->
    <script>
      const progressBar = document.getElementById('readingProgress');
      
      window.addEventListener('scroll', () => {
        const windowHeight = window.innerHeight;
        const documentHeight = document.documentElement.scrollHeight;
        const scrollTop = window.scrollY;
        const scrollPercent = (scrollTop / (documentHeight - windowHeight)) * 100;
        
        if (progressBar) {
          progressBar.style.width = `${Math.min(scrollPercent, 100)}%`;
        }
      });
    </script>

    <!-- Script: Table of Contents Highlighting Logic -->
    <script>
      const tocItems = document.querySelectorAll('.case-nav li');
      const headings = Array.from(document.querySelectorAll('.prose h1, .prose h2, .prose h3'));
      
      if (tocItems.length > 0 && headings.length > 0) {
        const observerOptions = {
          root: null,
          rootMargin: '-80px 0px -60%',
          threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              const activeLink = document.querySelector(`.case-nav a[href="#${id}"]`);
              
              if (activeLink) {
                tocItems.forEach(item => item.classList.remove('active'));
                activeLink.parentElement?.classList.add('active');
              }
            }
          });
        }, observerOptions);

        headings.forEach(h => observer.observe(h));
      }
    </script>

    <!-- Script: Zoomable Images Lightbox/Overlay -->
    <script>
      function initImageZoom() {
        const proseImages = document.querySelectorAll('.prose img');
        proseImages.forEach(img => {
          if (img.classList.contains('zoom-bound')) return;
          img.classList.add('zoom-bound');
          
          img.addEventListener('click', (e) => {
            e.stopPropagation();
            
            // Create fullscreen overlay
            const overlay = document.createElement('div');
            overlay.className = 'lightbox-overlay';
            
            const zoomedImg = document.createElement('img');
            zoomedImg.src = img.getAttribute('src') || '';
            zoomedImg.alt = img.getAttribute('alt') || 'Zoomed view';
            zoomedImg.className = 'lightbox-image';
            
            overlay.appendChild(zoomedImg);
            document.body.appendChild(overlay);
            
            // Prevent background page scrolling
            document.body.style.overflow = 'hidden';
            
            // Fade-in overlay & Zoom-in image
            requestAnimationFrame(() => {
              overlay.classList.add('active');
            });
            
            // Cleanup & close lightbox
            const closeLightbox = () => {
              overlay.classList.remove('active');
              overlay.addEventListener('transitionend', () => {
                overlay.remove();
                if (!document.querySelector('.lightbox-overlay')) {
                  document.body.style.overflow = '';
                }
              }, { once: true });
            };
            
            overlay.addEventListener('click', closeLightbox);
            
            // Close on ESC key press
            const escHandler = (event) => {
              // Cast event to KeyboardEvent safely
              if (event instanceof KeyboardEvent && event.key === 'Escape') {
                closeLightbox();
                document.removeEventListener('keydown', escHandler);
              }
            };
            document.addEventListener('keydown', escHandler);
          });
        });
      }

      // Initialize on load and custom transitions
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initImageZoom);
      } else {
        initImageZoom();
      }
      document.addEventListener('astro:page-load', initImageZoom);
    </script>
  </body>
</html>

<style>
  .post-main {
    background: var(--background);
    padding-top: var(--spacing-12);
  }

  .post-breadcrumbs {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--on-surface-muted);
    margin-bottom: var(--spacing-6);
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 1.5rem;
  }

  .breadcrumb {
    text-decoration: none;
    color: inherit;
    letter-spacing: 0.05em;
  }

  .breadcrumb.accent {
    color: var(--primary-accent);
  }

  .separator {
    color: var(--border-strong);
  }

  /* Centered Post Header */
  .post-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    gap: 0.8rem;
  }

  .post-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--on-surface-muted);
    margin: 0;
  }

  .eyebrow-divider {
    margin: 0 0.5rem;
    color: var(--border-strong);
  }

  .post-title {
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    line-height: 1.1;
    font-weight: 700;
    margin: 0;
    color: var(--on-surface);
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    max-width: 800px;
    text-wrap: balance;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--on-surface-muted);
  }

  .meta-divider {
    color: var(--border-strong);
  }

  .author-name {
    font-weight: 600;
    color: var(--on-surface);
  }

  .post-tags-centered {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .tag-pill {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--on-surface-variant);
    text-decoration: none;
    border: 1px solid var(--border-subtle);
    padding: 0.25rem 0.6rem;
    background: var(--surface-low);
    border-radius: var(--radius-sm);
    transition: all 0.15s ease;
  }

  .tag-pill:hover {
    color: var(--primary-accent);
    border-color: var(--primary-accent);
  }

  .header-divider {
    height: 1px;
    width: 100%;
    max-width: 860px;
    background: var(--border-subtle);
    margin: var(--spacing-8) auto;
  }

  /* 2-Column Content Layout */
  .content-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--spacing-12);
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .sidebar-left {
    position: sticky;
    top: 100px;
    padding-right: var(--spacing-4);
  }

  .sidebar-title {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--on-surface-muted);
    margin-bottom: var(--spacing-4);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .case-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .case-nav li {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--on-surface-variant);
    transition: all 0.2s ease;
    padding-left: 0.75rem;
    border-left: 2px solid var(--border-subtle);
    line-height: 1.3;
  }

  .case-nav li:hover {
    color: var(--on-surface);
    border-left-color: var(--border-strong);
  }

  .case-nav li.active {
    color: var(--primary-accent);
    font-weight: 600;
    border-left-color: var(--primary-accent);
  }

  .case-nav a {
    color: inherit;
    text-decoration: none;
  }

  .prose-wrapper {
    max-width: 720px;
    min-width: 0;
  }

  .prose {
    font-size: 0.975rem;
    line-height: 1.78;
    color: var(--on-surface-variant);
  }

  :global(.prose p) {
    font-size: 0.975rem;
    line-height: 1.78;
    color: var(--on-surface-variant);
    margin-bottom: 1.4rem;
    letter-spacing: 0;
  }

  :global(.prose h2) {
    font-size: 1.55rem;
    font-family: var(--font-display);
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--on-surface);
    letter-spacing: -0.01em;
  }

  :global(.prose h3) {
    font-size: 1.2rem;
    font-family: var(--font-display);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--on-surface);
    letter-spacing: -0.01em;
  }

  :global(.prose ul) {
    list-style-type: disc;
    margin-bottom: 1.4rem;
    padding-left: 1.5rem;
  }

  :global(.prose ol) {
    margin-bottom: 1.4rem;
    padding-left: 1.5rem;
  }

  :global(.prose li) {
    font-size: 0.975rem;
    line-height: 1.78;
    margin-bottom: 0.4rem;
    color: var(--on-surface-variant);
  }

  :global(.prose a) {
    color: var(--on-surface);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border-strong);
    text-decoration-thickness: 1px;
  }

  :global(.prose a:hover) {
    text-decoration-color: var(--on-surface);
  }

  :global(.prose blockquote) {
    border-left: 3px solid var(--border-strong);
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    color: var(--on-surface-muted);
    font-style: italic;
  }

  :global(.prose strong) {
    color: var(--on-surface);
    font-weight: 600;
  }

  /* Post Footer Actions */
  .post-footer {
    padding: var(--spacing-8) 0;
    border-top: 1px solid var(--border-subtle);
    max-width: 860px;
    margin: var(--spacing-12) auto var(--spacing-10) auto;
  }

  .footer-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--on-surface-muted);
  }

  .author-label {
    font-weight: 500;
  }

  .back-link {
    color: var(--on-surface-muted);
    font-weight: 500;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .back-link:hover {
    color: var(--primary-accent);
  }

  /* Scroll to Top Button styling */
  .scroll-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--surface-low);
    color: var(--on-surface-variant);
    border: 1px solid var(--border-subtle);
    width: 42px;
    height: 42px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 900;
  }

  .scroll-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .scroll-to-top:hover {
    border-color: var(--primary-accent);
    color: var(--primary-accent);
    background: var(--surface-container);
  }

  @media (max-width: 960px) {
    .content-layout {
      grid-template-columns: 1fr;
    }
    
    .sidebar-left {
      display: none;
    }
    
    .prose-wrapper {
      max-width: 100%;
    }
  }

  /* Zoomable images styling inside prose */
  :global(.prose img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md, 4px);
    margin: 2rem auto;
    display: block;
    border: 1px solid var(--border-subtle);
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.2s ease;
  }

  :global(.prose img:hover) {
    transform: scale(1.005);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  /* Lightbox overlay styling */
  :global(.lightbox-overlay) {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(245, 240, 230, 0.96); /* Warm parchment light theme overlay */
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    cursor: zoom-out;
    transition: opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global([data-theme="dark"] .lightbox-overlay) {
    background: rgba(20, 20, 22, 0.96); /* Deep charcoal dark theme overlay */
  }

  :global(.lightbox-overlay.active) {
    opacity: 1;
  }

  :global(.lightbox-image) {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    transform: scale(0.95);
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    user-select: none;
  }

  :global(.lightbox-overlay.active .lightbox-image) {
    transform: scale(1);
  }
</style>
